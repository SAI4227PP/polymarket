# syntax=docker/dockerfile:1
FROM golang:1.23 as builder
WORKDIR /workspace/go-services
COPY go-services/go.mod ./
RUN go mod download
COPY go-services/cmd ./cmd
COPY go-services/internal ./internal
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -mod=mod -o /out/api ./cmd/api

FROM gcr.io/distroless/static-debian12
WORKDIR /app
COPY --from=builder /out/api /app/api
EXPOSE 8080
ENTRYPOINT ["/app/api"]

