POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
# Leave IDs empty for auto mode.
# Set EVENT_URL or EVENT_SLUG only if you want a specific market page.
POLYMARKET_ASSET_ID=
POLYMARKET_MARKET_ID=
POLYMARKET_EVENT_URL=
POLYMARKET_EVENT_SLUG=
POLYMARKET_AUTO_EVENT_PREFIX=btc-updown-5m
POLYMARKET_AUTO_EVENT_MODE=epoch_5m
POLYMARKET_OUTCOME_ASSET_IDS=
POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-frontend-clob.polymarket.com/ws/market
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_DEBUG=1
TRADER_DEBUG_QUOTES=1
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SYMBOL=BTCUSDT

REDIS_URL=redis://localhost:6379
REDIS_TRADER_STATE_KEY=trader:state:latest
REDIS_SNAPSHOT_KEY=api:snapshot:latest
REDIS_STATUS_KEY=api:status:latest
REDIS_METRICS_KEY=api:metrics:latest
REDIS_TRADES_KEY=api:trades:latest
REDIS_FINAL_TRADES_KEY=trader:trades:latest
REDIS_CONFIG_KEY=api:config:latest

# Trader runtime
LOOP_INTERVAL_MS=1000
MIN_EDGE_BPS=8
ORDER_QTY=5
ORDER_NOTIONAL_USD=1
EXECUTION_EDGE_THRESHOLD_BPS=5
EXECUTION_MIN_NET_EDGE_MARGIN_BPS=3
EXECUTION_MAX_SLIPPAGE_BPS=80
POSITION_TTL_MS=10000
BINANCE_ANCHOR_PRICE=100000
BINANCE_BASIS_BPS=0
BINANCE_SIGNAL_WEIGHT=0.35
MAX_NOTIONAL_USD=10
MAX_DAILY_LOSS_USD=100
MAX_OPEN_POSITIONS=3
# Kill switch uses live PnL drawdown from peak once peak pnl reaches threshold.
KILL_SWITCH_DRAWDOWN_PCT=5
KILL_SWITCH_MIN_PEAK_PNL_USD=5
KILL_SWITCH_ERROR_STREAK=5
KILL_SWITCH_STALE_DATA_MS=15000
DEMO_WALLET_BALANCE_USD=10
LIVE_WALLET_BALANCE_USD=10
MIN_ORDER_NOTIONAL_USD=1
MIN_ORDER_SHARES=5
ACCOUNT_EQUITY_USD=10
TRADE_HISTORY_LIMIT=200
HOLD_STRONG_EDGE_BPS=5
INVALIDATION_CLOSE_BPS=6
NO_ENTRY_FIRST_SECONDS_5M=3
NO_ENTRY_LAST_SECONDS_5M=15
NEAR_CERTAINTY_HOLD_SECONDS=15

DATABASE_URL=postgres://user:pass@localhost:5432/polymarket
# paper and live use identical signal/risk/execution logic; only wallet source differs.
MODE=paper

